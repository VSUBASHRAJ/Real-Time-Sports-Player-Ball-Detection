    {
      "cell_type": "code",
      "source": [
        "# Load pre-trained YOLOv8 model (PyTorch-based)\n",
        "model = YOLO('yolov8n.pt')  # nano model, fast inference"
      ],
      "metadata": {
        "id": "F8omTJffInSn"
      },
      "execution_count": null,
      "outputs": []
