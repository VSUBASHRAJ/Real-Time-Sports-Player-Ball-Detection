    {
      "cell_type": "code",
      "source": [
        "# Run detection on video\n",
        "results = model.predict(source=video_path, conf=0.5, show=True)\n",
        "\n",
        "# Optional: Print detected objects per frame\n",
        "for frame_results in results:\n",
        "    for box in frame_results.boxes:\n",
        "        cls = int(box.cls[0])\n",
        "        if cls in [0, 32]:  # 0 = person, 32 = sports ball\n",
        "            print(f\"Detected {model.names[cls]} at {box.xyxy}\")\n"
